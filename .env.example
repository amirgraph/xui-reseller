# ─────────────────────────────────────────────────────────
#  نمونهٔ .env — این فایل فقط الگوست. مقادیر واقعی را
#  setup.sh هنگام نصب می‌سازد و در .env می‌نویسد (که در .gitignore است).
#  هیچ‌وقت .env واقعی را commit نکن.
# ─────────────────────────────────────────────────────────

# پنل رزلر (node)
PORT=3000
NODE_ENV=production
DB_PATH=./data/reseller.db
JWT_SECRET=<AUTO_GENERATED>

# سرور
SERVER_IP=<AUTO_DETECTED>

# ── x-ui ──
XUI_URL=http://127.0.0.1:38339
XUI_PATH=/<RANDOM_PATH>
XUI_USERNAME=admin
XUI_PASSWORD=<ASKED_AT_INSTALL>
XUI_API_KEY=<AUTO_GENERATED>

# ── تلگرام ──
TELEGRAM_BOT_TOKEN=<ASKED_AT_INSTALL>
ADMIN_TELEGRAM_ID=<ASKED_AT_INSTALL>

# ── دامنه‌ها / ساب ──
# دامنهٔ اصلی (پشت Arvan یا CDN داخلی): پنل + ساب پشتیبان
SUB_BASE_URL=https://<MAIN_DOMAIN>/sub
XUI_SUB_BASE=https://<MAIN_DOMAIN>/sub
# نهان: ۳ ساب‌دامینِ Cloudflare (ساب اصلی)
NAHAN_SUBS=<sub1>,<sub2>,<sub3>
SUB_BASE_FRB=https://<sub1>/sub
# IPهای تمیزِ Cloudflare (اسکنر خودکار پر می‌کند)
NAHAN_ADDRS=

# مسیر xhttp تونل (تصادفی)
CDN_XHTTP_PATH=/<RANDOM_XHTTP_PATH>
